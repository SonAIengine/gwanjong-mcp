# gwanjong-mcp environment variables
# Copy this file to ~/.gwanjong/.env and fill in your values.
# Or set GWANJONG_ENV_PATH to point to a custom location.

# ── Platform API Keys ──

# Dev.to (https://dev.to/settings/extensions → Generate API Key)
DEVTO_API_KEY=
DEVTO_USERNAME=

# Bluesky (https://bsky.app)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Twitter/X (https://developer.x.com → Bearer Token)
TWITTER_BEARER_TOKEN=
TWITTER_USERNAME=

# Reddit (https://www.reddit.com/prefs/apps → Create App)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# GitHub Discussions (https://github.com/settings/tokens)
GITHUB_TOKEN=
GITHUB_DISCUSSIONS_REPOS=owner/repo,owner2/repo2
GITHUB_DISCUSSIONS_DEFAULT_REPO=
GITHUB_DISCUSSIONS_CATEGORY_ID=
GITHUB_USERNAME=

# Discourse (https://meta.discourse.org/t/discourse-rest-api-documentation/22706)
DISCOURSE_BASE_URL=
DISCOURSE_BASE_URLS=
DISCOURSE_DEFAULT_BASE_URL=
DISCOURSE_API_KEY=
DISCOURSE_API_USERNAME=
DISCOURSE_DEFAULT_CATEGORY_ID=

# ── Autonomous Mode (optional) ──

# Required for SDK backend (CLI backend uses local auth)
ANTHROPIC_API_KEY=

# ── Custom Paths (optional, defaults shown) ──

# GWANJONG_ENV_PATH=~/.gwanjong/.env
# GWANJONG_DB_PATH=~/.gwanjong/memory.db
# GWANJONG_PERSONA_PATH=~/.gwanjong/persona.json
# GWANJONG_BROWSER_DATA_DIR=~/.gwanjong/browser-data
